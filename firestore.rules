rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scans
    // Document ID: Auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the owner
    //   - image: string (required) - Base64 image data
    //   - analysis: map (required) - The Gemini analysis result
    //   - timestamp: timestamp (required) - Server timestamp
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - role: string (required) - 'admin' or 'user'
    //   - email: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "raghav.kilambi@gmail.com" && isEmailVerified()));
    }

    function isRecent(time) {
      return time > request.time - duration.value(5, 'm') &&
             time <= request.time;
    }

    function isValidStringList(lst, maxItems, maxStrLen) {
      return lst is list && lst.size() <= maxItems &&
             (lst.size() == 0 || (lst[0] is string && lst[0].size() <= maxStrLen));
      // Note: Firestore rules don't have a simple way to iterate over all elements in a list.
      // A more robust way is to check the total size of the document, but we'll rely on the 1MB doc limit.
    }

    function isValidAnalysis(analysis) {
      let requiredFields = ['name', 'symptoms', 'treatment', 'seekDoctor', 'severity', 'confidence', 'disclaimer'];
      return analysis is map &&
             analysis.keys().hasAll(requiredFields) &&
             analysis.name is string && analysis.name.size() < 200 &&
             isValidStringList(analysis.symptoms, 20, 500) &&
             isValidStringList(analysis.treatment, 20, 500) &&
             isValidStringList(analysis.seekDoctor, 20, 500) &&
             analysis.severity in ['low', 'medium', 'high'] &&
             analysis.confidence is number &&
             analysis.disclaimer is string && analysis.disclaimer.size() < 1000;
    }

    function isValidScan(data) {
      let allowedFields = ['userId', 'image', 'analysis', 'timestamp'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(allowedFields) &&
             data.userId == request.auth.uid &&
             data.image is string &&
             data.image.size() > 100 &&
             data.image.size() < 1048576 && // 1MB limit for base64
             isValidAnalysis(data.analysis) &&
             data.timestamp is timestamp &&
             isRecent(data.timestamp);
    }

    function isValidUser(data) {
      let allowedFields = ['email', 'role', 'displayName'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email == request.auth.token.email &&
             data.role in ['admin', 'user'] &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() < 100));
    }

    match /scans/{scanId} {
      // Users can only read their own scans, admins can read all
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      // Users can only create scans for themselves
      allow create: if isAuthenticated() && isEmailVerified() && isValidScan(request.resource.data);
      
      // Scans are immutable to prevent tampering with history
      allow update: if false;
      
      // Users can delete their own scans
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      // PII Protection: Only owner or admin can read user profiles
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      
      // Initial user creation: must be owner, must be verified, must be 'user' role
      allow create: if isOwner(userId) && isEmailVerified() &&
                      isValidUser(request.resource.data) && 
                      request.resource.data.role == 'user';
      
      // Updates: Only admins can change roles. Users can only update their own profile without changing role.
      allow update: if isAuthenticated() && 
                      isValidUser(request.resource.data) && 
                      (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
