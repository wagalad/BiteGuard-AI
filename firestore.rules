rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scans
    // Document ID: Auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the owner
    //   - imagePath: string (required) - Firebase Storage path for the uploaded image
    //   - analysis: map (required) - The Gemini analysis result
    //   - timestamp: timestamp (required) - Server timestamp
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - role: string (required) - 'admin' or 'user'
    //   - email: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailVerified() {
      // In a real Google Sign In flow, email_verified is true.
      // We enforce this as a security best practice.
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isRecent(time) {
      return time > request.time - duration.value(5, 'm') &&
             time <= request.time;
    }

    function isValidStringAt(lst, index, maxStrLen) {
      return lst.size() <= index || (lst[index] is string && lst[index].size() <= maxStrLen);
    }

    function isValidStringList(lst, maxItems, maxStrLen) {
      return lst is list && lst.size() <= maxItems &&
             isValidStringAt(lst, 0, maxStrLen) &&
             isValidStringAt(lst, 1, maxStrLen) &&
             isValidStringAt(lst, 2, maxStrLen) &&
             isValidStringAt(lst, 3, maxStrLen) &&
             isValidStringAt(lst, 4, maxStrLen) &&
             isValidStringAt(lst, 5, maxStrLen) &&
             isValidStringAt(lst, 6, maxStrLen) &&
             isValidStringAt(lst, 7, maxStrLen) &&
             isValidStringAt(lst, 8, maxStrLen) &&
             isValidStringAt(lst, 9, maxStrLen) &&
             isValidStringAt(lst, 10, maxStrLen) &&
             isValidStringAt(lst, 11, maxStrLen) &&
             isValidStringAt(lst, 12, maxStrLen) &&
             isValidStringAt(lst, 13, maxStrLen) &&
             isValidStringAt(lst, 14, maxStrLen) &&
             isValidStringAt(lst, 15, maxStrLen) &&
             isValidStringAt(lst, 16, maxStrLen) &&
             isValidStringAt(lst, 17, maxStrLen) &&
             isValidStringAt(lst, 18, maxStrLen) &&
             isValidStringAt(lst, 19, maxStrLen);
    }

    function isValidAnalysis(analysis) {
      let requiredFields = ['name', 'symptoms', 'treatment', 'seekDoctor', 'severity', 'confidence', 'disclaimer'];
      return analysis is map &&
             analysis.keys().hasAll(requiredFields) &&
             analysis.name is string && analysis.name.size() < 200 &&
             isValidStringList(analysis.symptoms, 20, 500) &&
             isValidStringList(analysis.treatment, 20, 500) &&
             isValidStringList(analysis.seekDoctor, 20, 500) &&
             analysis.severity in ['low', 'medium', 'high'] &&
             analysis.confidence is number &&
             analysis.disclaimer is string && analysis.disclaimer.size() < 1000;
    }

    function isValidScan(data) {
      let allowedFields = ['userId', 'imagePath', 'analysis', 'timestamp'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(allowedFields) &&
             data.userId == request.auth.uid &&
             data.imagePath is string &&
             data.imagePath.size() > 10 &&
             data.imagePath.size() < 500 &&
             data.imagePath.matches('^scans/' + request.auth.uid + '/[a-zA-Z0-9\\-]+\\.jpg$') &&
             isValidAnalysis(data.analysis) &&
             data.timestamp is timestamp &&
             isRecent(data.timestamp);
    }

    function isValidUser(data) {
      let allowedFields = ['email', 'role', 'displayName'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(['email', 'role']) &&
             data.email is string && data.email == request.auth.token.email &&
             data.role in ['admin', 'user'] &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() < 100));
    }

    match /scans/{scanId} {
      allow list: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isAuthenticated() && isValidId(scanId) && (isAdmin() || resource.data.userId == request.auth.uid);
      
      allow create: if isAuthenticated() && isValidId(scanId) && isEmailVerified() && isValidScan(request.resource.data);
      
      allow update: if false;
      
      allow delete: if isAuthenticated() && isValidId(scanId) && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow get: if isAuthenticated() && isValidId(userId) && (isOwner(userId) || isAdmin());
      allow list: if isAuthenticated() && isAdmin(); // Only allow admins to list users
      
      allow create: if isValidId(userId) && isOwner(userId) && isEmailVerified() &&
                      isValidUser(request.resource.data) && 
                      request.resource.data.role == 'user';
      
      allow update: if isAuthenticated() && isValidId(userId) &&
                      isValidUser(request.resource.data) && 
                      (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }
  }
}
