rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scans
    // Document ID: Auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the owner
    //   - image: string (required) - Base64 image data
    //   - analysis: map (required) - The Gemini analysis result
    //   - timestamp: timestamp (required) - Server timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'image', 'analysis', 'timestamp']) &&
             data.userId is string &&
             data.image is string &&
             data.image.size() < 10485760 && // Limit image size in rules (approx 10MB)
             data.analysis is map &&
             data.timestamp is timestamp;
    }

    match /scans/{scanId} {
      // Users can only read their own scans
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      
      // Users can only create scans for themselves
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidScan(request.resource.data);
      
      // Scans are typically immutable in this app, but if we allow updates:
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == request.auth.uid &&
                      isValidScan(request.resource.data);
      
      // Users can delete their own scans
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
