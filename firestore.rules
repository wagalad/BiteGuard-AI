rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, createdAt
    //
    // Collection: scans
    // Fields: userId, timestamp, imageData, analysis (name, severity, confidence, etc.)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() < 256;
    }

    function isValidScan(data) {
      return data.keys().hasAll(['userId', 'timestamp', 'analysis', 'imageData']) &&
             data.userId == request.auth.uid &&
             data.analysis is map &&
             data.analysis.name is string &&
             data.analysis.severity in ['low', 'medium', 'high'] &&
             data.imageData is string &&
             data.imageData.size() < 10000000; // ~10MB limit for base64
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      // To bootstrap the first admin, manually set the 'role' field to 'admin' 
      // for your user document in the Firebase Console.
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /scans/{scanId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidScan(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
