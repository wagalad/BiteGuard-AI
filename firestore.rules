rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scans
    // Document ID: Auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the owner
    //   - image: string (required) - Base64 image data
    //   - analysis: map (required) - The Gemini analysis result
    //   - timestamp: timestamp (required) - Server timestamp
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - role: string (required) - 'admin' or 'user'
    //   - email: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "raghav.kilambi@gmail.com" && request.auth.token.email_verified == true));
    }

    function isRecent(time) {
      return time > request.time - duration.value(5, 'm') &&
             time <= request.time;
    }

    function isValidScan(data) {
      let allowedFields = ['userId', 'image', 'analysis', 'timestamp'];
      return data.keys().hasOnly(allowedFields) &&
             data.keys().hasAll(allowedFields) &&
             data.userId == request.auth.uid &&
             data.image is string &&
             data.image.size() > 100 &&
             data.image.size() < 10485760 &&
             data.analysis is map &&
             data.timestamp is timestamp &&
             isRecent(data.timestamp);
    }

    match /scans/{scanId} {
      // Users can only read their own scans, admins can read all
      allow read: if isAuthenticated() && (isAdmin() || (resource == null || resource.data.userId == request.auth.uid));
      
      // Users can only create scans for themselves
      allow create: if isAuthenticated() && isValidScan(request.resource.data);
      
      // Scans are immutable to prevent tampering with history
      allow update: if false;
      
      // Users can delete their own scans
      allow delete: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      // Only admins can create/update roles, except for initial user creation which defaults to 'user'
      allow create: if isAuthenticated() && isOwner(userId) && request.resource.data.role == 'user';
      allow update: if isAuthenticated() && isAdmin();
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
